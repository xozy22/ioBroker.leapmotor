{
  "i18n": false,
  "type": "tabs",
  "items": {
    "loginTab": {
      "type": "panel",
      "label": "Anmeldung",
      "items": {
        "_loginHeader": {
          "type": "staticText",
          "text": "Zugangsdaten deines Leapmotor-Kontos (Leapmotor International). Empfehlung: ein zweites Konto anlegen, das Fahrzeug in der offiziellen App dorthin teilen und dieses geteilte Konto hier verwenden – sonst kann dich die App ausloggen.",
          "newLine": true
        },
        "email": {
          "type": "text",
          "label": "E-Mail",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "password": {
          "type": "password",
          "label": "Passwort",
          "repeat": false,
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "vehiclePin": {
          "type": "password",
          "label": "Fahrzeug-PIN (optional, nur für Steuerbefehle)",
          "repeat": false,
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        }
      }
    },
    "certTab": {
      "type": "panel",
      "label": "Zertifikate",
      "items": {
        "_certHeader": {
          "type": "staticText",
          "text": "Der Login benötigt das App-Zertifikatsmaterial (app.crt / app.key) für die mTLS-Verbindung. Dieses Material ist nicht Teil des Adapters. Empfohlen: automatisch von einem Community-Repository laden. Alternativ kannst du es manuell hinterlegen.",
          "newLine": true
        },
        "certSource": {
          "type": "select",
          "label": "Zertifikatsquelle",
          "def": "auto",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "options": [
            { "label": "Automatisch von URL laden (empfohlen)", "value": "auto" },
            { "label": "Manuell (PEM-Inhalt oder Dateipfad)", "value": "manual" }
          ]
        },
        "_autoHint": {
          "type": "staticText",
          "hidden": "data.certSource === 'manual'",
          "text": "Hinweis: Es werden ein Client-Zertifikat und ein privater Schlüssel von der angegebenen URL geladen (Standard: markoceri/leapmotor-certs). Vertraue nur Quellen, die du kennst. Die Zertifikate werden lokal zwischengespeichert und bei jedem Adapterstart aktualisiert.",
          "newLine": true
        },
        "certUrlCrt": {
          "type": "text",
          "label": "URL zu app.crt",
          "hidden": "data.certSource === 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 8
        },
        "certUrlKey": {
          "type": "text",
          "label": "URL zu app.key",
          "hidden": "data.certSource === 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 8
        },
        "loadCertsBtn": {
          "type": "sendTo",
          "label": "Zertifikate jetzt laden & testen",
          "command": "loadCerts",
          "jsonData": "{\"certUrlCrt\": \"${data.certUrlCrt}\", \"certUrlKey\": \"${data.certUrlKey}\"}",
          "variant": "contained",
          "showProcessState": true,
          "hidden": "data.certSource === 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "_manualHint": {
          "type": "staticText",
          "hidden": "data.certSource !== 'manual'",
          "text": "Den vollständigen PEM-Inhalt einfügen ODER einen Dateipfad auf dem ioBroker-Host angeben.",
          "newLine": true
        },
        "appCertPem": {
          "type": "text",
          "label": "app.crt / app_cert.pem (PEM-Inhalt)",
          "maxRows": 8,
          "hidden": "data.certSource !== 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 6
        },
        "appKeyPem": {
          "type": "text",
          "label": "app.key / app_key.pem (PEM-Inhalt)",
          "maxRows": 8,
          "hidden": "data.certSource !== 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 6
        },
        "appCertPath": {
          "type": "text",
          "label": "Pfad zu app.crt (Alternative zum PEM-Inhalt)",
          "hidden": "data.certSource !== 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "appKeyPath": {
          "type": "text",
          "label": "Pfad zu app.key (Alternative zum PEM-Inhalt)",
          "hidden": "data.certSource !== 'manual'",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "accountP12Password": {
          "type": "password",
          "label": "Account-Zertifikatspasswort (optional, wird normalerweise automatisch abgeleitet)",
          "repeat": false,
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      }
    },
    "pollTab": {
      "type": "panel",
      "label": "Abruf",
      "items": {
        "pollInterval": {
          "type": "number",
          "label": "Abrufintervall (Minuten)",
          "min": 1,
          "max": 1440,
          "default": 5,
          "newLine": true,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "ecoPollingEnabled": {
          "type": "checkbox",
          "label": "Eco-Polling aktivieren (seltener abrufen, wenn das Fahrzeug weder fährt noch lädt)",
          "newLine": true,
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "ecoPollInterval": {
          "type": "number",
          "label": "Eco-Abrufintervall (Minuten)",
          "min": 1,
          "max": 1440,
          "default": 15,
          "hidden": "!data.ecoPollingEnabled",
          "newLine": true,
          "sm": 12,
          "md": 4,
          "lg": 3
        }
      }
    },
    "abrpTab": {
      "type": "panel",
      "label": "ABRP / EVCC",
      "items": {
        "_abrpHeader": {
          "type": "staticText",
          "text": "ABRP (A Better Routeplanner): sendet nach jedem Abruf Live-Telemetrie (Ladezustand, Position, Lade-Strom/-Spannung) an ABRP, damit die Routenplanung mit echten Werten rechnet. Du benötigst einen ABRP-Token: in der ABRP-App ein Fahrzeug vom Typ 'Generic' anlegen und dort den Telemetrie-Token kopieren.",
          "newLine": true
        },
        "abrpEnabled": {
          "type": "checkbox",
          "label": "ABRP-Telemetrie senden",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "abrpToken": {
          "type": "password",
          "label": "ABRP-Token",
          "repeat": false,
          "hidden": "!data.abrpEnabled",
          "newLine": true,
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "abrpApiKey": {
          "type": "text",
          "label": "ABRP-API-Key (optional, leer = Standard)",
          "hidden": "!data.abrpEnabled",
          "newLine": true,
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "_evccHint": {
          "type": "staticText",
          "text": "EVCC: Der Status-Datenpunkt charging.evcc_status (A = getrennt, B = verbunden, C = lädt) wird automatisch bereitgestellt und benötigt keine Konfiguration.",
          "newLine": true
        }
      }
    },
    "advancedTab": {
      "type": "panel",
      "label": "Erweitert",
      "items": {
        "_advHeader": {
          "type": "staticText",
          "text": "Diese Werte müssen normalerweise nicht geändert werden.",
          "newLine": true
        },
        "baseUrl": {
          "type": "text",
          "label": "API-Basis-URL",
          "default": "https://appgateway.leapmotor-international.de",
          "newLine": true,
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "language": {
          "type": "text",
          "label": "Sprache (acceptLanguage)",
          "default": "en-GB",
          "newLine": true,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "appVersion": {
          "type": "text",
          "label": "App-Version",
          "default": "1.12.3",
          "newLine": true,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "deviceId": {
          "type": "text",
          "label": "Feste Device-ID (optional, leer = automatisch)",
          "newLine": true,
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "_demoHeader": {
          "type": "header",
          "text": "Test / Demo",
          "size": 4,
          "newLine": true
        },
        "_demoHint": {
          "type": "staticText",
          "text": "Legt unter dem Fahrzeug \"DEMO\" die komplette Objektstruktur mit Null-Werten an – ohne Fahrzeugverbindung. So kannst du Visualisierungen/Skripte gegen die Objektadressen vorbereiten. Die Instanz muss dafür laufen. Später wieder löschen.",
          "newLine": true
        },
        "createDemoBtn": {
          "type": "sendTo",
          "label": "Demo-Objekte anlegen",
          "command": "createDemoObjects",
          "variant": "contained",
          "showProcessState": true,
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "deleteDemoBtn": {
          "type": "sendTo",
          "label": "Demo-Objekte löschen",
          "command": "deleteDemoObjects",
          "variant": "outlined",
          "showProcessState": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        }
      }
    }
  }
}
